# ============================================
# AI Receptionist Enterprise v4.0.0 — Environment
# NEVER commit .env to GitHub
# ALL values below are EXAMPLES. NO FALLBACKS exist in code.
# Missing required vars will crash the app at startup.
# ============================================

# Vapi AI Voice Agent
VAPI_API_KEY=your_vapi_api_key_here
VAPI_WEBHOOK_SECRET=your_webhook_secret_here

# Twilio SMS & Voice
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# Emergency Transfer (doctor's mobile for urgent calls)
EMERGENCY_PHONE_NUMBER=+971501234567

# Google Calendar
GOOGLE_CALENDAR_ID=primary
GOOGLE_CREDENTIALS_FILE=google_credentials.json

# PostgreSQL Database
DATABASE_URL=postgresql://user:password@localhost:5432/ai_receptionist

# Authentication
# SECRET_KEY: minimum 32 characters. Generate with: openssl rand -hex 32
SECRET_KEY=change-me-to-32-random-characters!!
# ADMIN_PASSWORD: strong password, never 'changeme123'
ADMIN_PASSWORD=changeme123
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Application
TIMEZONE=Asia/Dubai
LOG_LEVEL=INFO
# DASHBOARD_ORIGIN: exact URL of your GitHub Pages dashboard. NO WILDCARD.
DASHBOARD_ORIGIN=http://localhost:3000
ENVIRONMENT=development

# Quiet Hours (no SMS during these hours, queued for morning)
QUIET_HOURS_START=21
QUIET_HOURS_END=8

# Data Retention (days)
RETENTION_CALLS_DAYS=730
RETENTION_AUDIT_DAYS=365
RETENTION_SMS_QUEUE_DAYS=30

# Monitoring (optional)
SENTRY_DSN=https://xxx@yyy.ingest.sentry.io/zzz
