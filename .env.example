# ============================================
# AI Receptionist Enterprise -- Environment
# NEVER commit .env to GitHub
# ============================================

# Vapi AI Voice Agent
VAPI_API_KEY=your_vapi_api_key_here
VAPI_WEBHOOK_SECRET=your_webhook_secret_here

# Twilio SMS
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# Google Calendar
GOOGLE_CALENDAR_ID=primary
GOOGLE_CREDENTIALS_FILE=google_credentials.json

# PostgreSQL Database
DATABASE_URL=postgresql://user:password@localhost:5432/ai_receptionist

# Authentication
SECRET_KEY=change-me-to-32-random-characters!!
ADMIN_PASSWORD=changeme123
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Application
TIMEZONE=Asia/Dubai
LOG_LEVEL=INFO
DASHBOARD_ORIGIN=http://localhost:3000
ENVIRONMENT=development

# Optional: Emergency Transfer
EMERGENCY_PHONE_NUMBER=+1234567890

# Monitoring (optional)
SENTRY_DSN=https://xxx@yyy.ingest.sentry.io/zzz